<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <OutputType>Library</OutputType>
    <AssemblyName>GBFR.ExtraSigilSlots20.Reloaded</AssemblyName>
    <RootNamespace>GBFR.ExtraSigilSlots20.Reloaded</RootNamespace>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Reloaded.Mod.Interfaces" Version="2.5.0" ExcludeAssets="runtime" />
    <PackageReference Include="Reloaded.SharedLib.Hooks" Version="1.9.0" ExcludeAssets="runtime" />
    <PackageReference Include="Reloaded.Imgui.Hook" Version="4.1.0" />
    <PackageReference Include="Reloaded.Imgui.Hook.Direct3D11" Version="1.0.2" />
  </ItemGroup>

  <ItemGroup>
    <None Include="ModConfig.json" CopyToOutputDirectory="Always" />
    <None Include="README-development.md" CopyToOutputDirectory="Always" />
    <None Include="README-safety-test.md" CopyToOutputDirectory="Always" />
    <None Include="..\GBFR.ExtraSigilSlots20.Native\bin\$(Configuration)\GBFR.ExtraSigilSlots20.Native.dll"
          Link="GBFR.ExtraSigilSlots20.Native.dll"
          CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\GBFR.ExtraSigilSlots20.Native\GBFR-ExtraSigilSlots20.ini"
          Link="GBFR-ExtraSigilSlots20.ini"
          CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\GBFR.ExtraSigilSlots20.Native\GBFR-ExtraSigilSlots20.names.en.tsv"
          Link="GBFR-ExtraSigilSlots20.names.en.tsv"
          CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\GBFR.ExtraSigilSlots20.Native\GBFR-ExtraSigilSlots20.names.zh-CN.tsv"
          Link="GBFR-ExtraSigilSlots20.names.zh-CN.tsv"
          CopyToOutputDirectory="PreserveNewest" />
    <None Include="..\GBFR.ExtraSigilSlots20.Native\GBFR-ExtraSigilSlots20.compatibility.tsv"
          Link="GBFR-ExtraSigilSlots20.compatibility.tsv"
          CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>
